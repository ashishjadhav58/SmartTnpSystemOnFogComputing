# LLM Provider Configuration
# Options: groq (recommended - fast & free), openai, anthropic, ollama, fallback
LLM_PROVIDER=groq

# Groq Configuration (RECOMMENDED - Fast LLaMA 3, Free)
# Get your API key from https://console.groq.com/keys
# Models: llama-3.1-8b-instant (fast), llama-3.1-70b-versatile (accurate), mixtral-8x7b-32768 (long context)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# OpenAI Configuration (if using OpenAI)
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic Configuration (if using Anthropic)
# Get your API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Ollama Configuration (if using local LLaMA)
# Install Ollama from https://ollama.ai
# Then run: ollama pull llama2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2
